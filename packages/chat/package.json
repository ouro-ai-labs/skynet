{
  "name": "@skynet-ai/chat",
  "version": "0.3.3",
  "description": "Chat TUI for human participation in Skynet multi-agent network",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ouro-ai-labs/skynet.git",
    "directory": "packages/chat"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node -e \"try{const r=require.resolve('@pinixai/weixin-bot/package.json');const p=require('path').dirname(r);if(!require('fs').existsSync(p+'/dist'))require('child_process').execSync('npx tsc',{cwd:p,stdio:'inherit'})}catch{}\"",
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skynet-ai/protocol": "workspace:*",
    "@skynet-ai/sdk": "workspace:*",
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4"
  },
  "optionalDependencies": {
    "@pinixai/weixin-bot": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
